{
  "multipart": [
    {
      "apply": { "model": "cobaltage:block/cobalt_dust_dot" },
      "when": {
        "OR": [
          { "east": "none", "north": "none", "south": "none", "west": "none" },
          { "east": "side|up", "north": "side|up" },
          { "east": "side|up", "south": "side|up" },
          { "south": "side|up", "west": "side|up" },
          { "north": "side|up", "west": "side|up" }
        ]
      }
    },
    {
      "apply": { "model": "cobaltage:block/cobalt_dust_side0" },
      "when": { "north": "side|up" }
    },
    {
      "apply": { "model": "cobaltage:block/cobalt_dust_side_alt0" },
      "when": { "south": "side|up" }
    },
    {
      "apply": { "model": "cobaltage:block/cobalt_dust_side_alt1", "y": 270 },
      "when": { "east": "side|up" }
    },
    {
      "apply": { "model": "cobaltage:block/cobalt_dust_side1", "y": 270 },
      "when": { "west": "side|up" }
    },
    {
      "apply": { "model": "cobaltage:block/cobalt_dust_up" },
      "when": { "north": "up" }
    },
    {
      "apply": { "model": "cobaltage:block/cobalt_dust_up", "y": 90 },
      "when": { "east": "up" }
    },
    {
      "apply": { "model": "cobaltage:block/cobalt_dust_up", "y": 180 },
      "when": { "south": "up" }
    },
    {
      "apply": { "model": "cobaltage:block/cobalt_dust_up", "y": 270 },
      "when": { "west": "up" }
    },
    {
      "when": { "power": 0 },
      "apply": { "model": "cobaltage:block/cobalt_power_level_00" }
    },
    {
      "when": { "power": 1 },
      "apply": { "model": "cobaltage:block/cobalt_power_level_01" }
    },
    {
      "when": { "power": 2 },
      "apply": { "model": "cobaltage:block/cobalt_power_level_02" }
    },
    {
      "when": { "power": 3 },
      "apply": { "model": "cobaltage:block/cobalt_power_level_03" }
    },
    {
      "when": { "power": 4 },
      "apply": { "model": "cobaltage:block/cobalt_power_level_04" }
    },
    {
      "when": { "power": 5 },
      "apply": { "model": "cobaltage:block/cobalt_power_level_05" }
    },
    {
      "when": { "power": 6 },
      "apply": { "model": "cobaltage:block/cobalt_power_level_06" }
    },
    {
      "when": { "power": 7 },
      "apply": { "model": "cobaltage:block/cobalt_power_level_07" }
    },
    {
      "when": { "power": 8 },
      "apply": { "model": "cobaltage:block/cobalt_power_level_08" }
    },
    {
      "when": { "power": 9 },
      "apply": { "model": "cobaltage:block/cobalt_power_level_09" }
    },
    {
      "when": { "power": 10 },
      "apply": { "model": "cobaltage:block/cobalt_power_level_10" }
    },
    {
      "when": { "power": 11 },
      "apply": { "model": "cobaltage:block/cobalt_power_level_11" }
    },
    {
      "when": { "power": 12 },
      "apply": { "model": "cobaltage:block/cobalt_power_level_12" }
    },
    {
      "when": { "power": 13 },
      "apply": { "model": "cobaltage:block/cobalt_power_level_13" }
    },
    {
      "when": { "power": 14 },
      "apply": { "model": "cobaltage:block/cobalt_power_level_14" }
    },
    {
      "when": { "power": 15 },
      "apply": { "model": "cobaltage:block/cobalt_power_level_15" }
    }
  ]
}