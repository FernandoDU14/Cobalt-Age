{
  "multipart": [
    {
      "when": { "cobalt_lit": "false", "redstone_lit": "false", "facing": "north" },
      "apply": { "model": "cobaltage:block/converter_off" }
    },
    {
      "when": { "cobalt_lit": "false", "redstone_lit": "false", "facing": "east" },
      "apply": { "model": "cobaltage:block/converter_off", "y": 90 }
    },
    {
      "when": { "cobalt_lit": "false", "redstone_lit": "false", "facing": "south" },
      "apply": { "model": "cobaltage:block/converter_off", "y": 180 }
    },
    {
      "when": { "cobalt_lit": "false", "redstone_lit": "false", "facing": "west" },
      "apply": { "model": "cobaltage:block/converter_off", "y": 270 }
    },
    {
      "when": { "cobalt_lit": "true", "facing": "north" },
      "apply": { "model": "cobaltage:block/converter_cobalt_on" }
    },
    {
      "when": { "cobalt_lit": "true", "facing": "east" },
      "apply": { "model": "cobaltage:block/converter_cobalt_on", "y": 90 }
    },
    {
      "when": { "cobalt_lit": "true", "facing": "south" },
      "apply": { "model": "cobaltage:block/converter_cobalt_on", "y": 180 }
    },
    {
      "when": { "cobalt_lit": "true", "facing": "west" },
      "apply": { "model": "cobaltage:block/converter_cobalt_on", "y": 270 }
    },

    {
      "when": { "redstone_lit": "true", "facing": "north" },
      "apply": { "model": "cobaltage:block/converter_redstone_on" }
    },
    {
      "when": { "redstone_lit": "true", "facing": "east" },
      "apply": { "model": "cobaltage:block/converter_redstone_on", "y": 90 }
    },
    {
      "when": { "redstone_lit": "true", "facing": "south" },
      "apply": { "model": "cobaltage:block/converter_redstone_on", "y": 180 }
    },
    {
      "when": { "redstone_lit": "true", "facing": "west" },
      "apply": { "model": "cobaltage:block/converter_redstone_on", "y": 270 }
    }
  ]
}